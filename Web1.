<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pawtique — CoreGut for Cats Investor Pitch Deck</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
–cream: #FDF8F0;
–warm-white: #FFFCF5;
–card: #FFFFFF;
–yellow: #F0C040;
–yellow-light: #FFF3C4;
–yellow-mid: #F5D060;
–teal: #7BBDB5;
–teal-light: #D4F0EC;
–teal-mid: #9DCFC8;
–brown: #3D2B1F;
–brown-mid: #6B4C3B;
–brown-light: #A0806C;
–brown-xlight: #D4B9AE;
–blush: #F5E6D8;
–shadow: 0 4px 24px rgba(61,43,31,0.08);
–shadow-sm: 0 2px 12px rgba(61,43,31,0.06);
–shadow-lg: 0 8px 40px rgba(61,43,31,0.12);
–radius: 20px;
–radius-sm: 12px;
–radius-lg: 32px;
}

/* ── Global chart canvas containment ── */
.chart-canvas-wrap {
position: relative; flex: 1; min-height: 0; overflow: hidden;
}
.chart-canvas-wrap canvas {
position: absolute !important; inset: 0;
width: 100% !important; height: 100% !important;
}

html, body {
width: 100%; height: 100%; overflow: hidden;
font-family: ‘DM Sans’, sans-serif;
background: #2A1F18;
}

/* ── Slide System — always 1280×720, scaled to fit any screen ── */
.deck {
width: 100vw; height: 100vh;
position: relative; overflow: hidden;
display: flex; align-items: center; justify-content: center;
}

/* Stage: the 1280×720 canvas that gets scaled */
.stage {
width: 1280px; height: 720px;
position: relative; flex-shrink: 0;
transform-origin: center center;
}

.slide {
position: absolute; inset: 0;
display: flex; align-items: center; justify-content: center;
opacity: 0; pointer-events: none;
transition: opacity 0.5s ease, transform 0.5s ease;
transform: translateX(50px);
}
.slide.active {
opacity: 1; pointer-events: all; transform: translateX(0);
}
.slide.exit {
opacity: 0; transform: translateX(-50px);
}

.slide-inner {
width: 1280px; height: 720px;
position: relative;
overflow: hidden;
}

/* ── Navigation ── */
.nav-dots {
position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%);
display: flex; gap: 8px; z-index: 100;
}
.nav-dot {
width: 8px; height: 8px; border-radius: 50%;
background: rgba(255,255,255,0.4); cursor: pointer;
transition: all 0.3s; border: none; padding: 0;
}
.nav-dot.active { background: #F0C040; width: 24px; border-radius: 4px; }

.nav-btn {
position: fixed; top: 50%; transform: translateY(-50%);
background: rgba(255,255,255,0.15); border: none; cursor: pointer;
width: 44px; height: 44px; border-radius: 50%;
display: flex; align-items: center; justify-content: center;
color: white; font-size: 18px; z-index: 100;
transition: background 0.2s;
backdrop-filter: blur(8px);
}
.nav-btn:hover { background: rgba(255,255,255,0.28); }
.nav-btn.prev { left: 20px; }
.nav-btn.next { right: 20px; }

.slide-counter {
position: fixed; top: 20px; right: 24px; z-index: 100;
font-family: ‘Nunito’, sans-serif; font-size: 13px; font-weight: 700;
color: rgba(255,255,255,0.5); letter-spacing: 0.5px;
}

/* ── Common Slide Base ── */
.s-bg {
width: 100%; height: 100%;
background: var(–cream);
display: flex; flex-direction: column;
position: relative; overflow: hidden;
}

/* ── Decorative blobs ── */
.blob {
position: absolute; border-radius: 50%; pointer-events: none;
}

h1, h2, h3, h4 { font-family: ‘Nunito’, sans-serif; }

.slide-tag {
font-family: ‘Nunito’, sans-serif; font-size: 11px; font-weight: 800;
letter-spacing: 2px; text-transform: uppercase;
color: var(–brown-light); opacity: 0.7;
}

.card {
background: var(–card); border-radius: var(–radius);
box-shadow: var(–shadow);
}

