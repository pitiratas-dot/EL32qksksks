<script>
  // ── Viewport Scaling — fits 1280×720 to any screen ──
  const SLIDE_W = 1280, SLIDE_H = 720;
  function scaleStage() {
    const stage = document.getElementById('stage');
    const scaleX = window.innerWidth / SLIDE_W;
    const scaleY = window.innerHeight / SLIDE_H;
    const scale = Math.min(scaleX, scaleY);
    stage.style.transform = `scale(${scale})`;
  }
  scaleStage();
  window.addEventListener('resize', scaleStage);

  let current = 0;
  const slides = document.querySelectorAll('.slide');
  const dotsEl = document.getElementById('navDots');
  const counter = document.getElementById('slideCounter');

  // Create dots
  slides.forEach((_, i) => {
    const d = document.createElement('button');
    d.className = 'nav-dot' + (i === 0 ? ' active' : '');
    d.onclick = () => goTo(i);
    dotsEl.appendChild(d);
  });

  function goTo(n) {
    slides[current].classList.remove('active');
    slides[current].classList.add('exit');
    setTimeout(() => slides[current].classList.remove('exit'), 550);
    current = (n + slides.length) % slides.length;
    slides[current].classList.add('active');
    document.querySelectorAll('.nav-dot').forEach((d, i) => d.classList.toggle('active', i === current));
    counter.textContent = (current + 1) + ' / ' + slides.length;
    if (current === 2 && !window._s3drawn) { requestAnimationFrame(() => { drawMarketChart(); window._s3drawn = true; }); }
    if (current === 6 && !window._s7drawn) { requestAnimationFrame(() => { drawTractionChart(); window._s7drawn = true; }); }
    if (current === 8 && !window._s9drawn) { requestAnimationFrame(() => { drawFinancialChart(); window._s9drawn = true; }); }
  }

  function changeSlide(dir) { goTo(current + dir); }

  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') changeSlide(1);
    if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') changeSlide(-1);
  });

  // Touch/swipe support
  let touchStartX = 0;
  document.addEventListener('touchstart', e => touchStartX = e.touches[0].clientX, { passive: true });
  document.addEventListener('touchend', e => {
    const dx = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(dx) > 50) changeSlide(dx > 0 ? 1 : -1);
  }, { passive: true });

  // ── Chart: Market Opportunity ──
  function drawMarketChart() {
    const ctx = document.getElementById('marketChart');
    if (!ctx) return;
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: ['2025', '2026', '2027', '2028', '2029', '2030'],
        datasets: [{
          label: 'Market Size (USD M)',
          data: [1020, 1141, 1277, 1428, 1598, 1790],
          backgroundColor: [
            '#FFF3C4','#F5E87A','#F0D850','#E8C830','#E0B820','#D4A820'
          ],
          borderRadius: 10,
          borderSkipped: false,
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: ctx => ` USD ${ctx.raw}M`
            }
          }
        },
        scales: {
          y: {
            beginAtZero: false, min: 900,
            grid: { color: '#F0EBE4' },
            ticks: { color: '#A0806C', font: { family: 'DM Sans', size: 11 }, callback: v => `$${v}M` }
          },
          x: { grid: { display: false }, ticks: { color: '#A0806C', font: { family: 'DM Sans', size: 11 } } }
        }
      }
    });
  }

  // ── Chart: Year 1 Traction ──
  function drawTractionChart() {
    const ctx = document.getElementById('tractionChart');
    if (!ctx) return;
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: ['Q1', 'Q2', 'Q3', 'Q4'],
        datasets: [{
          label: 'Units Sold',
          data: [150, 250, 400, 600],
          backgroundColor: ['#FFF3C4', '#F5D860', '#F0C040', '#D4A820'],
          borderRadius: 12,
          borderSkipped: false,
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: ctx => ` ${ctx.raw} units` } }
        },
        scales: {
          y: {
            beginAtZero: true,
            grid: { color: '#F0EBE4' },
            ticks: { color: '#A0806C', font: { family: 'DM Sans', size: 11 } }
          },
          x: { grid: { display: false }, ticks: { color: '#3D2B1F', font: { family: 'Nunito', size: 13, weight: '700' } } }
        }
      }
    });
  }

  // ── Chart: Financial ──
  function drawFinancialChart() {
    const ctx = document.getElementById('financialChart');
    if (!ctx) return;
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: ['Y1', 'Y2', 'Y3', 'Y4', 'Y5'],
        datasets: [
          {
            type: 'bar',
            label: 'Revenue',
            data: [1921400, 4745160, 7265850, 9868300, 12836700],
            backgroundColor: '#FFF3C4',
            borderColor: '#F0C040',
            borderWidth: 2,
            borderRadius: 8,
            borderSkipped: false,
            yAxisID: 'y',
            order: 2
          },
          {
            type: 'line',
            label: 'EBIT',
            data: [333900, 1121910, 2007050, 2832060, 3760370],
            borderColor: '#7BBDB5',
            backgroundColor: 'rgba(123,189,181,0.12)',
            borderWidth: 3,
            pointBackgroundColor: '#7BBDB5',
            pointRadius: 5,
            tension: 0.4,
            fill: true,
            yAxisID: 'y',
            order: 1
          }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: {
            display: true,
            position: 'top',
            labels: { color: '#6B4C3B', font: { family: 'Nunito', size: 12, weight: '700' }, boxWidth: 12, boxHeight: 12 }
          },
          tooltip: { callbacks: { label: ctx => ` ${(ctx.raw/1000000).toFixed(2)}M THB` } }
        },
        scales: {
          y: {
            beginAtZero: true,
            grid: { color: '#F0EBE4' },
            ticks: { color: '#A0806C', font: { family: 'DM Sans', size: 10 }, callback: v => `${(v/1000000).toFixed(1)}M` }
          },
          x: { grid: { display: false }, ticks: { color: '#3D2B1F', font: { family: 'Nunito', size: 13, weight: '700' } } }
        }
      }
    });
  }

  // Draw slide 1 charts on load (market chart is slide 3)
  // Pre-draw if slide 3 is visible on load
  window.addEventListener('load', () => {
    scaleStage();
    if (current === 2) { requestAnimationFrame(() => { drawMarketChart(); window._s3drawn = true; }); }
    if (current === 6) { requestAnimationFrame(() => { drawTractionChart(); window._s7drawn = true; }); }
    if (current === 8) { requestAnimationFrame(() => { drawFinancialChart(); window._s9drawn = true; }); }
  });
</script>

